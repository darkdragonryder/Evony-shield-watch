# =========================================================
# Evony Shield Watch - Environment Configuration
# =========================================================

# ---------------------------------------------------------
# Discord
# ---------------------------------------------------------

DISCORD_TOKEN=your_discord_bot_token_here

# Bot owner Discord ID
OWNER_ID=123456789012345678


# ---------------------------------------------------------
# Telegram
# ---------------------------------------------------------

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here


# ---------------------------------------------------------
# Timezone / Reset Settings
# ---------------------------------------------------------

# Main server timezone
HOST_TIMEZONE=Australia/Sydney

# Daily reset time (24h format)
RESET_HOUR=17
RESET_MINUTE=0


# ---------------------------------------------------------
# Event Defaults
# ---------------------------------------------------------

DEFAULT_EVENT=svs


# ---------------------------------------------------------
# Optional Debug
# ---------------------------------------------------------

DEBUG=false
