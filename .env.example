# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# Bot Owner ID
OWNER_ID=123456789012345678

# Your timezone where server reset is 5pm
HOST_TIMEZONE=America/New_York

# Server reset time (24h format)
RESET_HOUR=17
RESET_MINUTE=0

# Optional: Twilio SMS
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE=

# Optional: Pushover push notifications
PUSHOVER_APP_TOKEN=
